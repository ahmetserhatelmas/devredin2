# Kopyala: cp .env.example .env — değerleri doldur (Git’e gitmez)
# Sonra: npm run build  →  js/runtime-config.js

SUPABASE_URL=
SUPABASE_ANON_KEY=
GOOGLE_MAPS_API_KEY=

# Canlı site kökü (SONDA / OLMADAN). E-posta ile giden şifre sıfırlama ve doğrulama linkleri buraya gider.
# Vercel’de mutlaka: https://devretlink.com  (veya www kullanıyorsan o adres)
# Boş bırakılırsa tarayıcıdaki origin kullanılır (localhost’ta geliştirme için).
SITE_URL=https://devretlink.com

# Vercel: Environment Variables’a aynı isimlerle ekle.
